# Payment Service — Environment Variables

# AMQP connection string for RabbitMQ.
# Format: amqp://user:password@host:port/vhost
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Maximum number of unacknowledged messages the broker sends to this consumer
# at once. Increase for higher throughput; decrease for fairer load balancing
# across multiple instances.
QOS_PREFETCH=10

# Maximum number of retry attempts before a message is routed to the DLQ.
# Each retry adds an exponential backoff delay via TTL wait queues:
#   Attempt 1 → wait 5s  (payment.process.wait.5s)
#   Attempt 2 → wait 15s (payment.process.wait.15s)
#   Attempt 3 → wait 45s (payment.process.wait.45s)
MAX_RETRIES=3

# Timeout in milliseconds for a single payment gateway call.
GATEWAY_TIMEOUT_MS=5000
